# Required: your tenant's host. The Orgo API resolves tenant from the Host header,
# so calls to https://app.orgo.space return 404 for tenant-scoped endpoints.
# Use your subdomain (e.g. acme.orgo.space) or a custom domain.
ORGO_TENANT_HOST=your-org.orgo.space

# One of the following auth methods. ApiToken is preferred for server-to-server use.

# 1) Long-lived API token. Generate at Settings → Developers → API Access.
#    Read-only tokens will 403 on any non-GET request.
ORGO_API_TOKEN=

# 2) JWT (alternative). Obtained from POST /api/v1/login or POST /api/v1/verify-login-otp.
#    Valid ~11 days; the server will not refresh it automatically.
# ORGO_JWT=

# 3) OAuth2 access token (alternative). Obtained via the Authorization Code flow.
# ORGO_OAUTH_TOKEN=

# 4) Contact hash (alternative, anonymous contact context only).
# ORGO_CONTACT_HASH=

# Optional: protocol (defaults to https). Use http for local development behind a proxy.
# ORGO_PROTOCOL=https

# Optional: per-request timeout in milliseconds (default 30000).
# ORGO_TIMEOUT_MS=30000
